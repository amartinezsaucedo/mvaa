<node id="class:se.citerus.dddsample.infrastructure.sampledata.SampleVoyages">
  <data key="d0">"class:se.citerus.dddsample.infrastructure.sampledata.SampleVoyages"</data>
  <data key="d1">"SampleVoyages"</data>
  <data key="d2">"clase"</data>
  <data key="d3">"Clase SampleVoyages"</data>
  <data key="d4">{"fan_in": 0, "fan_out": 0}</data>
  <data key="d5">{"archivo": "monoliths/cargo/SampleVoyages.java"}</data>
  <data key="d6">[]</data>
  <data key="d7">false</data>
  <data key="d8">null</data>
  <data key="d9">"Java class sample voyages located in package se.citerus.dddsample.infrastructure.sampledata. Uses related classes carrier movement, schedule, voyage, voyage number. Defines methods create voyage, get all, lookup."</data>
  <data key="d10">"The SampleVoyages class is responsible for managing a collection of Voyage objects, providing operations to create new voyages, retrieve all existing voyages, and look up specific voyages."</data>
