<node id="class:se.citerus.dddsample.config.DDDSampleApplicationContext">
  <data key="d0">"class:se.citerus.dddsample.config.DDDSampleApplicationContext"</data>
  <data key="d1">"DDDSampleApplicationContext"</data>
  <data key="d2">"clase"</data>
  <data key="d3">"Clase DDDSampleApplicationContext"</data>
  <data key="d4">{"fan_in": 0, "fan_out": 0}</data>
