<node id="class:se.citerus.dddsample.interfaces.handling.ws.HandlingReport">
  <data key="d0">"class:se.citerus.dddsample.interfaces.handling.ws.HandlingReport"</data>
  <data key="d1">"HandlingReport"</data>
  <data key="d2">"clase"</data>
  <data key="d3">"Clase HandlingReport"</data>
