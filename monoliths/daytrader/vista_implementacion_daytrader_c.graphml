<node id="class:com.ibm.websphere.samples.daytrader.direct.TradeDirect">
  <data key="d0">"class:com.ibm.websphere.samples.daytrader.direct.TradeDirect"</data>
  <data key="d1">"TradeDirect"</data>
  <data key="d2">"clase"</data>
