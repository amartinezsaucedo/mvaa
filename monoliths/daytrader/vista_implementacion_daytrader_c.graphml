<node id="class:com.ibm.websphere.samples.daytrader.ejb3.TradeSLSBBean">
  <data key="d0">"class:com.ibm.websphere.samples.daytrader.ejb3.TradeSLSBBean"</data>
  <data key="d1">"TradeSLSBBean"</data>
  <data key="d2">"clase"</data>
