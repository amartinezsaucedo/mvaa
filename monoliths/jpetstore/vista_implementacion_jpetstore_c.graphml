    <node id="class:org.mybatis.jpetstore.domain.Product">
      <data key="d0">"class:org.mybatis.jpetstore.domain.Product"</data>
      <data key="d1">"Product"</data>
      <data key="d2">"clase"</data>
      <data key="d3">""</data>
      <data key="d4">{"fan_in": 0, "fan_out": 0}</data>
      <data key="d5">{}</data>
      <data key="d6">"Java class product located in package org.mybatis.jpetstore.domain. Defines methods get category id, get description, get name, get product id, set category id, set description, set name, set product id, to string."</data>
      <data key="d7">"The Product class is responsible for managing product information, providing methods to get and set product ID, category ID, name, and description, as well as a string representation of the product."</data>
